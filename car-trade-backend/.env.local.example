# ============================================================
# 5D 好车 · 本地开发环境变量模板
# ============================================================
# 用法：
#   1. 复制此文件为 `.env.local`：
#        cp .env.local.example .env.local
#   2. 填入真实值（不要提交到 git —— 已在 .gitignore 排除）
#   3. 启动后端前先 source：
#        - PowerShell:  . .\scripts\load-env.ps1
#        - Git Bash:     . scripts/load-env.sh
# ============================================================

# ----- 数据库（必填）-----
DB_URL=jdbc:postgresql://localhost:5432/new_car_trade?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&currentSchema=public
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ----- Redis（必填）-----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- JWT 签名密钥（必填，至少 32 字节，不要使用默认值！）-----
#   生成方式：openssl rand -base64 48   （推荐）
#   或       [System.Web.Security.Membership]::GeneratePassword(48,0)
#   当前 dev 用的占位值：dev-only-jwt-secret-please-change-min-32-bytes-2026
JWT_SECRET=dev-only-jwt-secret-please-change-min-32-bytes-2026

# ----- RocketMQ（可选，未配会走降级逻辑）-----
ROCKETMQ_NAME_SERVER=
ROCKETMQ_ACCESS_KEY=
ROCKETMQ_SECRET_KEY=
ROCKETMQ_NAMESPACE=

# ----- 阿里云 SLS 日志（可选）-----
SLS_ENDPOINT=
SLS_PROJECT=
SLS_LOGSTORE=
SLS_ACCESS_KEY_ID=
SLS_ACCESS_KEY_SECRET=

# ----- AI（Volcengine Ark / coding/v3）-----
AI_ENABLED=true
AI_API_KEY=
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
AI_MODEL=doubao-seed-2.0-lite

# ----- CORS 白名单（逗号分隔，生产环境必须显式指定）-----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- 业务开关 -----
APP_DEMO_MODE=false
